rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Production: only signed-in Firebase Auth users can read/write rental data.
    match /{collection}/{document} {
      allow read, write: if request.auth != null
        && collection in ['cars', 'customers', 'rentals', 'fines', 'accidents', 'payments'];
    }
  }
}
