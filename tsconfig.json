{
  "extends": "@react-native/typescript-config",
  "compilerOptions": {
    "types": ["jest"],
    "strict": true,
    "baseUrl": ".",
    "paths": {
      "@app/*": ["src/app/*"],
      "@core/*": ["src/core/*"],
      "@contextApis/*": ["src/contextApis/*"],
      "@error/*": ["src/error/*"],
      "@shared/*": ["src/shared/*"],
      "@features/*": ["src/features/*"],
      "@network/*": ["src/network/*"],
      "@zustand/*": ["src/zustand/*"],
      "@locales/*": ["src/locales/*"]
    }
  },
  "include": ["src/**/*.ts", "src/**/*.tsx", "App.tsx", "index.js"],
  "exclude": ["**/node_modules", "**/Pods"]
}
