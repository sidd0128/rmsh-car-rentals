# Copy to `.env` and fill in values. `.env` is gitignored.
# Restart Metro after changes: npm start -- --reset-cache

# development | staging | production
APP_ENV=development

# Settings → "Wipe all data" (still hidden when __DEV__ is false in release builds)
SHOW_DEV_DATA_TOOLS=true

# Firebase Web app (Console → Project settings → Your apps → Web)
# Leave empty to run local-only without cloud sync.
FIREBASE_API_KEY=
FIREBASE_AUTH_DOMAIN=
FIREBASE_PROJECT_ID=
FIREBASE_STORAGE_BUCKET=
FIREBASE_MESSAGING_SENDER_ID=
FIREBASE_APP_ID=
FIREBASE_MEASUREMENT_ID=
